# OS Generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# EPUB files: inputs (e.g. personal/copyrighted books) and generated outputs.
# Never commit e-books to the repository.
*.epub
*_report.txt

# Scanned-book inputs for the OCR spike (often copyrighted) — never commit.
*.pdf
/tests/ocr-samples/

# OCR/PDF research spikes — throwaway standalone crates kept locally only.
/spikes/

# Local environment (secrets like GOOGLE_BOOKS_API_KEY) — never commit your real
# .env; the .env.example template IS committed.
.env
!.env.example

# Runtime logs written by epublift-web (EPUBLIFT_LOG_DIR, default ./logs).
/logs/
**/logs/

# Editor / IDE
.idea/
.vscode/

# Claude Code local settings
.claude/settings.local.json
