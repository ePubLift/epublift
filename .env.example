# epublift-web — local environment for `docker compose`.
#
# Copy this file to `.env` (in the same folder as docker-compose.yml) and fill in
# the values you need. Docker Compose loads `.env` automatically — no `export`,
# no editing the compose file:
#
#     cp .env.example .env      # then edit .env
#     docker compose up -d
#
# Keep your real `.env` private — it's git-ignored.

# Optional — Google Books API key for the Metadata editor's ISBN enrichment.
# Anonymous Google Books requests share a small daily quota (HTTP 429 once it's
# exhausted). A free key raises it: https://console.cloud.google.com/ → create a
# project → enable the "Books API" → Credentials → create an API key.
# Leave this blank to use Open Library only (the default provider; no key needed).
GOOGLE_BOOKS_API_KEY=

# Optional — Mistral API key to enable [EXPERIMENTAL] "Smart Import": AI OCR that
# turns a PDF (including scans/photos) into an EPUB. Get one at
# https://console.mistral.ai/. Leave blank to keep Smart Import switched off in
# the UI. NOTE: with this set, uploaded PDFs are sent to Mistral for OCR, and the
# server's key (not the user's) pays for the calls.
MISTRAL_API_KEY=
